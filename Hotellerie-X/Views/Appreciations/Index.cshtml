@model IEnumerable<Hotellerie_X.Models.HotellerieModel.Appreciation>

@{
    ViewData["Title"] = "Appreciations";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Ajouter une appréciation</a>
        <a asp-controller="Hotels" asp-action="Index" class="btn btn-info">Retour aux hôtels</a>
    </p>
    
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Nom Personne</th>
                <th>Commentaire</th>
                <th>Note</th>
                <th>Hôtel</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.NomPers)</td>
                <td>@Html.DisplayFor(modelItem => item.Commentaire)</td>
                <td>@Html.DisplayFor(modelItem => item.Note) / 10</td>
                <td>@Html.DisplayFor(modelItem => item.Hotel.Nom)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Éditer</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Détails</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Supprimer</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
