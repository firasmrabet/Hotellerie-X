@model IEnumerable<Hotellerie_X.Models.HotellerieModel.Hotel>

@{
    ViewData["Title"] = "Hotels";
}

<div class="container mt-4">
    <h1>@ViewData["Title"]</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Créer un nouvel hôtel</a>
        <a asp-controller="Appreciations" asp-action="Index" class="btn btn-info">Voir les appréciations</a>
    </p>
    
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Etoiles</th>
                <th>Ville</th>
                <th>Site Web</th>
                <th>Téléphone</th>
                <th>Pays</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.Nom)</td>
                <td>@Html.DisplayFor(modelItem => item.Etoiles)</td>
                <td>@Html.DisplayFor(modelItem => item.Ville)</td>
                <td><a href="@item.SiteWeb" target="_blank">@item.SiteWeb</a></td>
                <td>@Html.DisplayFor(modelItem => item.Tel)</td>
                <td>@Html.DisplayFor(modelItem => item.Pays)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Éditer</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Détails</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Supprimer</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
